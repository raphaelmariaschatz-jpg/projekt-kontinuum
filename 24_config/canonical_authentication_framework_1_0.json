  "risk_register": [
    {
      "id": "CAF-RISK-001",
      "severity": "high",
      "finding": "SessionContext can infer creator and authenticated status from a name.",
      "recommendation": "Treat as legacy compatibility only and replace with CAF result validation."
    },
    {
      "id": "CAF-RISK-002",
      "severity": "high",
      "finding": "Authorization consumers trust mutable session dictionaries.",
      "recommendation": "Introduce immutable CAF authentication results and verify freshness and assurance."
    },
    {
      "id": "CAF-RISK-003",
      "severity": "medium",
      "finding": "Legacy SHA-256 hashes remain accepted for migration.",
      "recommendation": "Keep migration path, measure remaining use, and block new legacy creation."
    },
    {
      "id": "CAF-RISK-004",
      "severity": "medium",
      "finding": "Recovery key lifecycle is discovered but not fully governed.",
      "recommendation": "Define rotation, expiry, revocation and audit before relying on recovery."
    },
    {
      "id": "CAF-RISK-005",
      "severity": "medium",
      "finding": "Large historical security surfaces exist in versioned data and backups.",
      "recommendation": "Keep archived, classify with ALP/CAM, and prevent accidental reactivation."
    }
  ],
