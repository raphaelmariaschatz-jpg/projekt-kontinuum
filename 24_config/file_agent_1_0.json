    ".json",
    ".kfx",
    ".log",
    ".md",
    ".pdf",
    ".py",
    ".txt",
    ".xlsx"
  ],
  "allowed_roots": [
    ".",
    "30_import",
    "14_documents",
    "04_knowledge",
    "06_learning"
