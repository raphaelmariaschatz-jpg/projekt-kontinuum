{
  "enabled": true,
  "provider": "search_provider_router",
  "provider_order": [
    "local_knowledge",
    "notebook_knowledge",
    "university_sources",
    "arxiv",
    "semantic_scholar",
    "brave_search",
    "duckduckgo_html",
    "duckduckgo_lite"
  ],
  "fallback_providers": ["duckduckgo_html", "duckduckgo_lite"],
