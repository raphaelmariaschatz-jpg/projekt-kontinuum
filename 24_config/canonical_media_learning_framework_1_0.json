  "adaptive_selection_criteria": [
    "learning_goal",
    "topic_structure",
    "competency_area",
    "complexity",
    "user_preference",
    "evidence_need",
    "accessibility",
    "overload_risk"
  ],
  "adaptive_selection_rules": [
    "Use the simplest medium that cleanly fulfils the learning goal.",
    "Add a second medium only when it improves understanding, transfer or safety.",
    "Use visual learning for relationships, structures and processes.",
    "Use interactive learning for checking understanding and practice.",
    "Use practical learning only when prerequisites, risks and goal are clear.",
    "Use reflective learning after complex or error-prone learning steps.",
    "Reduce media variety when overload is likely.",
    "Do not store persistent preferences without separate governance approval."
  ],
  "interfaces": [
    {
      "component": "Foundation Layer",
      "purpose": "Protect identity, principles and responsibility.",
      "boundary": "CMLF must not override Foundation."
    },
    {
      "component": "Governance Layer",
      "purpose": "Approval, review, privacy and risk boundaries.",
      "boundary": "CMLF does not decide autonomously."
    },
    {
      "component": "Canonical Architecture",
      "purpose": "CMIBF and framework registry alignment.",
      "boundary": "CMIBF remains normative."
    },
    {
      "component": "CPVF",
      "purpose": "Long-term project vision and mission.",
      "boundary": "CMLF does not automatically operationalize CPVF."
    },
    {
      "component": "CIF",
      "purpose": "Intelligence dimensions.",
      "boundary": "CMLF defines media, not intelligence."
    },
    {
      "component": "CCP-Cognitive",
      "purpose": "Cognitive processing and response preparation.",
      "boundary": "CMLF does not replace the pipeline."
    },
    {
      "component": "CAICF",
      "purpose": "Competency target space.",
      "boundary": "CMLF conveys competencies, does not define them."
    },
    {
      "component": "CVF",
      "purpose": "Computer Vision and visual perception.",
      "boundary": "CVF analyzes visual content; CMLF selects learning media."
    },
    {
      "component": "CRE",
      "purpose": "Future capability resolution.",
      "boundary": "CMLF does not resolve capabilities."
    },
    {
      "component": "Execution Planner",
      "purpose": "Future planning of learning steps.",
      "boundary": "CMLF creates no runtime plans."
    },
    {
      "component": "Orchestrator Core",
      "purpose": "Execution of validated plans.",
      "boundary": "CMLF executes nothing."
    },
    {
      "component": "Canonical Memory",
      "purpose": "Storage of validated learning evidence.",
      "boundary": "No direct memory write."
    },
    {
      "component": "Tutor / Education",
      "purpose": "Adaptive learning support.",
      "boundary": "No tutor implementation in CMLF 1.0."
    }
  ],
  "extension_points": [
    "Media Recommendation Policy",
    "Tutor Media Profile",
    "Accessibility Profile",
    "Cognitive Load Model",
    "Multimodal Learning Plans",
    "Evidence-aware Learning Outputs",
    "Media Effectiveness Review"
  ],
  "non_goals": [
    "runtime changes",
    "CRE changes",
    "Execution Planner changes",
    "Orchestrator Core changes",
    "new agent implementation",
    "database migration",
    "automatic media generation",
    "refactoring",
    "automatic storage of user preferences"
  ]
}
