{
  "framework": "Canonical Media Learning Framework",
  "abbreviation": "CMLF",
  "version": "1.0",
  "status": "conceptual",
  "date": "2026-07-16",
  "runtime_effect": "none",
  "purpose": "Canonical framework for media types, representation forms and learning methods used to convey knowledge and competencies in Projekt Kontinuum.",
  "governance_result": {
    "concept_preparation": "GO",
    "implementation": "SPAETER",
    "runtime_effect": "none"
  },
  "boundaries": {
    "caicf": "defines competencies to be developed",
    "cmlf": "defines media and learning-output forms for conveying competencies",
    "ccp_cognitive": "defines the cognitive processing and response preparation pipeline",
    "cvf": "reserved for Computer Vision, visual perception, interpretation and image processing"
  },
  "media_areas": [
