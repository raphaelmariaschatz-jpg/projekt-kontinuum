{
  "framework_information": {
    "id": "CLMSF-1.0",
    "name": "Canonical Licence Management System Framework",
    "abbreviation": "CLMSF",
    "version": "1.0",
    "status": "implemented_with_limitations",
    "date": "2026-07-18",
    "runtime_effect": "explicit_structural_declaration_review_only",
    "purpose": "Canonical architecture and validation contract for future licence mechanisms without enforcement."
